# syntax=docker/dockerfile:1
#
# agent_server v2 — single all-in-one image with CUDA + Python +
# llama-cpp-python (mtmd enabled) + the v2 application code.
#
# Diverges from v1's BASE+APP split (agent_server.server.Dockerfile +
# agent_server.Dockerfile) on three deliberate points:
#   1. ONE Dockerfile, one image. Self-contained — no inheritance from
#      v1's `agent_server-server:1.0`. v1 stays untouched as rollback.
#   2. CUDA 13.2.1 / Ubuntu 24.04 / Python 3.12 (vs v1's 12.9 / 22.04 /
#      3.10). Forward-looking; matches what was on disk + just-pulled.
#   3. CMAKE_ARGS does NOT include `-DLLAMA_BUILD_TOOLS=OFF`. That flag
#      strips mtmd from the build, which is exactly the bit we need for
#      vision. We keep tests/examples disabled (faster build) but let
#      the tools/library group compile so libmtmd ships in the wheel.
#
# Build:
#   docker build -t agent_server_v2:1.0 -f Dockerfile.v2 .
#
# Run (via docker compose):
#   docker compose -f docker-compose.v2.yml up -d
#
# Iterate on Python code: edit app/, rebuild — only the COPY layer
# rebuilds (~10 s) thanks to layer caching.

FROM nvidia/cuda:13.2.1-cudnn-devel-ubuntu24.04

ARG DEBIAN_FRONTEND=noninteractive

# System deps. Ubuntu 24.04 ships Python 3.12.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-venv python3-pip \
    build-essential cmake git curl ca-certificates \
    gcc-12 g++-12 libgomp1 \
 && rm -rf /var/lib/apt/lists/*

# Venv
RUN python3.12 -m venv /opt/venv
ENV PATH=/opt/venv/bin:$PATH \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN pip install --upgrade pip

# --- Python dependencies (pinned; mirrors v1 BASE list, excluding
#     llama-cpp-python which builds from source below) ---
RUN pip install --no-cache-dir \
    aiohappyeyeballs==2.6.1 \
    aiohttp==3.12.15 \
    aiosignal==1.4.0 \
    annotated-types==0.7.0 \
    anyio==4.10.0 \
    async-timeout==5.0.1 \
    attrs==25.3.0 \
    bidict==0.23.1 \
    click==8.3.0 \
    diskcache==5.6.3 \
    exceptiongroup==1.3.0 \
    fastapi==0.116.2 \
    frozenlist==1.7.0 \
    h11==0.16.0 \
    httpx==0.28.0 \
    idna==3.10 \
    Jinja2==3.1.6 \
    MarkupSafe==3.0.2 \
    multidict==6.6.4 \
    numpy==2.2.6 \
    propcache==0.3.2 \
    pydantic==2.11.9 \
    pydantic_core==2.33.2 \
    python-engineio==4.12.2 \
    python-socketio==5.13.0 \
    simple-websocket==1.1.0 \
    sniffio==1.3.1 \
    starlette==0.48.0 \
    typing_extensions==4.15.0 \
    typing-inspection==0.4.1 \
    uvicorn==0.35.0 \
    wsproto==1.2.0 \
    yarl==1.20.1

# --- Build llama-cpp-python with CUDA + mtmd ---
ENV CC=/usr/bin/gcc-12 \
    CXX=/usr/bin/g++-12 \
    CUDAHOSTCXX=/usr/bin/g++-12

# CMAKE_ARGS deliberately drops `-DLLAMA_BUILD_TOOLS=OFF` so mtmd is
# built into the wheel (vision support). Tests/examples stay off to
# keep the build fast. Build for sm_89 only (target hw is RTX 4090);
# cuts build time vs default multi-arch.
ENV CMAKE_ARGS="-DGGML_CUDA=on -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_EXAMPLES=OFF -DCMAKE_CUDA_ARCHITECTURES=89" \
    FORCE_CMAKE=1

# CUDA driver stubs (real driver attaches at runtime)
ENV LIBRARY_PATH=/usr/local/cuda/lib64/stubs:${LIBRARY_PATH} \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64/stubs:${LD_LIBRARY_PATH} \
    LDFLAGS="-L/usr/local/cuda/lib64/stubs -Wl,-rpath-link,/usr/local/cuda/lib64/stubs"
RUN ln -sf /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/libcuda.so \
 && ln -sf /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/libcuda.so.1 \
 && ln -sf /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/stubs/libcuda.so.1

# Build backend + helpers for no-build-isolation
RUN pip install --no-cache-dir \
    'scikit-build-core>=0.10' \
    ninja \
    setuptools \
    wheel \
    packaging

# Build llama-cpp-python from PyPI source dist (no GitHub clone, no
# submodule pin) — the released wheel's bundled llama.cpp commit is
# recent enough for Gemma 4 vision. Verified empirically 2026-05-02.
RUN pip uninstall -y llama-cpp-python || true \
 && pip cache purge \
 && pip install --no-cache-dir --no-build-isolation --force-reinstall llama-cpp-python

# --- Application layer (rebuilds fast on code changes) ---
WORKDIR /agent_server

COPY ./app/ ./app/
COPY ./agent_config.json ./agent_config.json

ENV PYTHONPATH=/agent_server

EXPOSE 7701

CMD ["uvicorn", "app.main:asgi_app", "--host", "0.0.0.0", "--port", "7701"]
